# Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# App Configuration
NEXT_PUBLIC_APP_NAME=CyberNow
NEXT_PUBLIC_COMPANY_NAME=Bloyi Innovations Pvt Limited

# Authentication
NEXT_PUBLIC_JWT_TOKEN_KEY=cybernow_token
NEXT_PUBLIC_TOKEN_EXPIRY=86400

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_LOGGING=true
